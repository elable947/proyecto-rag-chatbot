# ── Proveedor de LLM ──────────────────────────────
LLM_PROVIDER=ollama              # ollama | anthropic | openai | deepseek
LLM_API_KEY=                     # solo para anthropic, openai o deepseek
LLM_MODEL=qwen2:1.5b

# ── Embeddings ────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3

# ── Base de datos vectorial ───────────────────────
VECTOR_DB_PATH=./data/processed/chroma
VECTOR_DB_COLLECTION=documentos_proyecto

# ── Parámetros RAG ────────────────────────────────
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── API ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]
